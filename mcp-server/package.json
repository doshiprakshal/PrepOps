{
  "name": "prepops-mcp-server",
  "version": "2.0.0",
  "private": true,
  "description": "PrepOps Remote MCP Server — Cloudflare Worker",
  "scripts": {
    "bundle": "tsx scripts/bundle-assets.ts",
